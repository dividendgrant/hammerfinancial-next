=\"2\" d=\"M4 6h16M4 12h16M4 18h16\"></path></svg></button></div></header><main class=\"flex-1\"><section class=\"relative bg-[#0A2279] overflow-hidden min-h-[520px] flex items-center\"><div class=\"absolute inset-0\"><img alt=\"\" decoding=\"async\" data-nimg=\"fill\" class=\"object-cover opacity-60\" style=\"position:absolute;height:100%;width:100%;left:0;top:0;right:0;bottom:0;color:transparent\" sizes=\"100vw\" srcSet=\"/_next/image?url=%2Fhero-bg.png&amp;w=640&amp;q=75 640w, /_next/image?url=%2Fhero-bg.png&amp;w=750&amp;q=75 750w, /_next/image?url=%2Fhero-bg.png&amp;w=828&amp;q=75 828w, /_next/image?url=%2Fhero-bg.png&amp;w=1080&amp;q=75 1080w, /_next/image?url=%2Fhero-bg.png&amp;w=1200&amp;q=75 1200w, /_next/image?url=%2Fhero-bg.png&amp;w=1920&amp;q=75 1920w, /_next/image?url=%2Fhero-bg.png&amp;w=2048&amp;q=75 2048w, /_next/image?url=%2Fhero-bg.png&amp;w=3840&amp;q=75 3840w\" src=\"/_next/image?url=%2Fhero-bg.png&amp;w=3840&amp;q=75\"/></div><div class=\"relative max-w-6xl mx-auto px-4 sm:px-6 py-20 grid grid-cols-1 lg:grid-cols-2 gap-10 items-center\"><div class=\"text-white\"><h1 class=\"text-4xl sm:text-5xl font-bold leading-tight mb-5\">Your partner in creating long-term crypto income</h1><p class=\"text-lg text-blue-100 leading-relaxed mb-8\">We show you how we use crypto ETFs and yield funds to build income today, while laying the foundation for tomorrow&#x27;s financial freedom.</p><div class=\"flex flex-wrap gap-4\"><a class=\"bg-white text-[#0057AD] font-semibold px-6 py-3 rounded-md hover:bg-blue-50 transition-colors\" href=\"/funds\">View Funds</a><a class=\"border-2 border-white text-white font-semibold px-6 py-3 rounded-md hover:bg-white/10 transition-colors\" href=\"/work-with-us\">Work with Us</a></div></div><div class=\"hidden lg:flex justify-end\"><img alt=\"\" loading=\"lazy\" width=\"380\" height=\"460\" decoding=\"async\" data-nimg=\"1\" class=\"object-contain drop-shadow-2xl\" style=\"color:transparent\" srcSet=\"/_next/image?url=%2Fhero-person.png&amp;w=384&amp;q=75 1x, /_next/image?url=%2Fhero-person.png&amp;w=828&amp;q=75 2x\" src=\"/_next/image?url=%2Fhero-person.png&amp;w=828&amp;q=75\"/></div></div></section><section class=\"py-20 bg-white\"><div class=\"max-w-6xl mx-auto px-4 sm:px-6\"><div class=\"text-center mb-12\"><h2 class=\"text-3xl font-bold text-gray-900 mb-3\">Our Funds</h2><p class=\"text-gray-500 max-w-xl mx-auto\">Simple strategies — steady ETF growth with Bitcoin and aggressive crypto yield opportunities.</p></div><div class=\"grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6\"><div class=\"border border-gray-200 rounded-xl p-6 hover:shadow-md transition-shadow flex flex-col\"><div class=\"w-10 h-10 bg-[#0057AD]/10 rounded-lg flex items-center justify-center mb-4\"><svg class=\"w-5 h-5 text-[#0057AD]\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M13 7h8m0 0v8m0-8l-8 8-4-4-6 6\"></path></svg></div><h3 class=\"font-bold text-gray-900 mb-2\">Hammer Income</h3><p class=\"text-sm text-gray-500 leading-relaxed flex-1\">Generate consistent cash flow through crypto yield ETFs including BTCI, BCCC, BLOX, and more. Income is used for real-world utility or reinvested into the Treasury fund.</p><a class=\"mt-4 text-sm font-semibold text-[#0057AD] hover:underline\" href=\"/funds\">Learn more →</a></div><div class=\"border border-gray-200 rounded-xl p-6 hover:shadow-md transition-shadow flex flex-col\"><div class=\"w-10 h-10 bg-[#0057AD]/10 rounded-lg flex items-center justify-center mb-4\"><svg class=\"w-5 h-5 text-[#0057AD]\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M13 7h8m0 0v8m0-8l-8 8-4-4-6 6\"></path></svg></div><h3 class=\"font-bold text-gray-900 mb-2\">Hammer Treasury</h3><p class=\"text-sm text-gray-500 leading-relaxed flex-1\">Capture the momentum of the growing crypto treasury trend — 70% Bitcoin, 10% Ethereum, 10% Solana, 10% Sui. Built for personal or corporate treasury reserves.</p><a class=\"mt-4 text-sm font-semibold text-[#0057AD] hover:underline\" href=\"/funds\">Learn more →</a></div><div class=\"border border-gray-200 rounded-xl p-6 hover:shadow-md transition-shadow flex flex-col\"><div class=\"w-10 h-10 bg-[#0057AD]/10 rounded-lg flex items-center justify-center mb-4\"><svg class=\"w-5 h-5 text-[#0057AD]\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M13 7h8m0 0v8m0-8l-8 8-4-4-6 6\"></path></svg></div><h3 class=\"font-bold text-gray-900 mb-2\">Hammer Long Term</h3><p class=\"text-sm text-gray-500 leading-relaxed flex-1\">A simple set-it-and-forget-it mix of broad market ETFs (SCHB, SCHD, FTEC) with a 10% Bitcoin allocation for steady, minimal-management growth.</p><a class=\"mt-4 text-sm font-semibold text-[#0057AD] hover:underline\" href=\"/funds\">Learn more →</a></div><div class=\"border border-gray-200 rounded-xl p-6 hover:shadow-md transition-shadow flex flex-col\"><div class=\"w-10 h-10 bg-[#0057AD]/10 rounded-lg flex items-center justify-center mb-4\"><svg class=\"w-5 h-5 text-[#0057AD]\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M13 7h8m0 0v8m0-8l-8 8-4-4-6 6\"></path></svg></div><h3 class=\"font-bold text-gray-900 mb-2\">Hammer Growth</h3><p class=\"text-sm text-gray-500 leading-relaxed flex-1\">Aggressive capital appreciation — 85% Bitcoin, 15% Fidelity MSCI Information Technology (FTEC). Built for the sharpest possible upward trajectory.</p><a class=\"mt-4 text-sm font-semibold text-[#0057AD] hover:underline\" href=\"/funds\">Learn more →</a></div></div></div></section><section class=\"py-20 bg-gray-50\"><div class=\"max-w-6xl mx-auto px-4 sm:px-6\"><h2 class=\"text-3xl font-bold text-gray-900 text-center mb-12\">What our community says</h2><div class=\"grid grid-cols-1 md:grid-cols-3 gap-8\"><div class=\"bg-white rounded-xl p-8 shadow-sm border border-gray-100\"><svg class=\"w-8 h-8 text-[#0057AD] mb-4\" fill=\"currentColor\" viewBox=\"0 0 24 24\"><path d=\"M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z\"></path></svg><p class=\"text-gray-600 leading-relaxed mb-4 italic\">&quot;<!-- -->Their focus on yield strategies helped me turn my crypto into a steady income stream I can actually track.<!-- -->&quot;</p><p class=\"font-semibold text-gray-900 text-sm\">Phyllis Lacker</p></div><div class=\"bg-white rounded-xl p-8 shadow-sm border border-gray-100\"><svg class=\"w-8 h-8 text-[#0057AD] mb-4\" fill=\"currentColor\" viewBox=\"0 0 24 24\"><path d=\"M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z\"></path></svg><p class=\"text-gray-600 leading-relaxed mb-4 italic\">&quot;<!-- -->I finally understand how to capture yield opportunities in crypto, thanks to their clear approach.<!-- -->&quot;</p><p class=\"font-semibold text-gray-900 text-sm\">Jeffrey Hudson</p></div><div class=\"bg-white rounded-xl p-8 shadow-sm border border-gray-100\"><svg class=\"w-8 h-8 text-[#0057AD] mb-4\" fill=\"currentColor\" viewBox=\"0 0 24 24\"><path d=\"M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z\"></path></svg><p class=\"text-gray-600 leading-relaxed mb-4 italic\">&quot;<!-- -->I never knew building a personal crypto treasury could be this straightforward — highly recommend.<!-- -->&quot;</p><p class=\"font-semibold text-gray-900 text-sm\">Maria Araya</p></div></div></div></section><section class=\"py-20 bg-white\"><div class=\"max-w-6xl mx-auto px-4 sm:px-6 grid grid-cols-1 md:grid-cols-2 gap-8\"><div class=\"bg-[#0057AD] rounded-2xl p-10 text-white flex flex-col justify-between\"><div><h2 class=\"text-2xl font-bold mb-3\">Crypto Insights</h2><p class=\"text-blue-100 leading-relaxed\">Stay up to date with our latest analysis, fund updates, and market perspectives.</p></div><a class=\"mt-8 inline-block bg-white text-[#0057AD] font-semibold px-6 py-3 rounded-md hover:bg-blue-50 transition-colors text-center\" href=\"/news\">Read Insights</a></div><div class=\"bg-[#0A2279] rounded-2xl p-10 text-white flex flex-col justify-between\"><div><h2 class=\"text-2xl font-bold mb-3\">Live Updates</h2><p class=\"text-blue-100 leading-relaxed\">Follow <strong>@DividendGrant</strong> on X for real-time portfolio moves, yield updates, and crypto market commentary.</p></div><a href=\"https://x.com/DividendGrant\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"mt-8 inline-flex items-center gap-2 bg-white text-[#0A2279] font-semibold px-6 py-3 rounded-md hover:bg-blue-50 transition-colors\"><svg class=\"w-4 h-4\" fill=\"currentColor\" viewBox=\"0 0 24 24\"><path d=\"M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z\"></path></svg>Follow on X</a></div></div></section><!--$--><!--/$--></main><footer class=\"bg-[#0A2279] text-white\"><div class=\"max-w-6xl mx-auto px-4 sm:px-6 py-12\"><div class=\"grid grid-cols-1 md:grid-cols-3 gap-8 mb-10\"><div><img alt=\"Hammer Financial\" loading=\"lazy\" width=\"160\" height=\"43\" decoding=\"async\" data-nimg=\"1\" class=\"brightness-0 invert mb-4\" style=\"color:transparent\" srcSet=\"/_next/image?url=%2Flogo.png&amp;w=256&amp;q=75 1x, /_next/image?url=%2Flogo.png&amp;w=384&amp;q=75 2x\" src=\"/_next/image?url=%2Flogo.png&amp;w=384&amp;q=75\"/><p class=\"